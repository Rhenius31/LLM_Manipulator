<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="table">
    <static>true</static>
    <pose>0 0 0 0 0 0</pose>

    <!-- Label: table = 3 -->
    <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
      <label>3</label>
    </plugin>

    <link name="link">

      <!-- Tabletop -->
      <!-- center at 0.58 so surface = 0.60 -->
      <collision name="top_collision">
        <pose>0 0 0.58 0 0 0</pose>
        <geometry>
          <box><size>0.8 0.6 0.04</size></box>
        </geometry>
      </collision>

      <visual name="top_visual">
        <pose>0 0 0.58 0 0 0</pose>
        <geometry>
          <box><size>0.8 0.6 0.04</size></box>
        </geometry>
        <material>
          <diffuse>0.55 0.35 0.2 1</diffuse>
        </material>
      </visual>

      <!-- Legs -->
      <!-- height = 0.56 -->
      <!-- center = 0.28 -->

      <collision name="leg1_col">
        <pose>0.35 0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
      </collision>
      <visual name="leg1_vis">
        <pose>0.35 0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
        <material><diffuse>0.25 0.18 0.12 1</diffuse></material>
      </visual>

      <collision name="leg2_col">
        <pose>0.35 -0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
      </collision>
      <visual name="leg2_vis">
        <pose>0.35 -0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
        <material><diffuse>0.25 0.18 0.12 1</diffuse></material>
      </visual>

      <collision name="leg3_col">
        <pose>-0.35 0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
      </collision>
      <visual name="leg3_vis">
        <pose>-0.35 0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
        <material><diffuse>0.25 0.18 0.12 1</diffuse></material>
      </visual>

      <collision name="leg4_col">
        <pose>-0.35 -0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
      </collision>
      <visual name="leg4_vis">
        <pose>-0.35 -0.25 0.28 0 0 0</pose>
        <geometry><box><size>0.05 0.05 0.56</size></box></geometry>
        <material><diffuse>0.25 0.18 0.12 1</diffuse></material>
      </visual>

    </link>
  </model>
</sdf>
