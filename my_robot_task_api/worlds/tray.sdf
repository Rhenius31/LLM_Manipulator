<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="tray">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <!-- Label: tray = 4 -->
    <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
      <label>4</label>
    </plugin>

    <link name="link">
      <inertial>
        <mass>0.5</mass>
      </inertial>

      <collision name="collision">
        <geometry>
          <box><size>0.30 0.20 0.03</size></box>
        </geometry>
      </collision>

      <visual name="base">
        <geometry>
          <box><size>0.30 0.20 0.03</size></box>
        </geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material>
      </visual>

      <!-- Rim visual (purely visual) -->
      <visual name="rim">
        <pose>0 0 0.02 0 0 0</pose>
        <geometry>
          <box><size>0.32 0.22 0.02</size></box>
        </geometry>
        <material><diffuse>0.15 0.15 0.15 1</diffuse></material>
        <transparency>0.5</transparency>
      </visual>
    </link>
  </model>
</sdf>
