<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="cup">
    <static>false</static>
    <pose>0 0 0 0 0 0</pose>

    <!-- Label: cup = 1 -->
    <plugin filename="gz-sim-label-system" name="gz::sim::systems::Label">
      <label>1</label>
    </plugin>

    <link name="link">
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0002</ixx><iyy>0.0002</iyy><izz>0.0002</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>

      <!-- Simple collision -->
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
      </collision>

      <!-- Outer wall visual -->
      <visual name="outer">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.10</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.9 0.9 0.9 1</diffuse>
        </material>
      </visual>

      <!-- Inner cavity visual -->
      <visual name="inner_cavity">
        <pose>0 0 0.01 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.022</radius>
            <length>0.08</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
        <transparency>0.3</transparency>
      </visual>
    </link>
  </model>
</sdf>
